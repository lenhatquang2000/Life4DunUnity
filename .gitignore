# This .gitignore file is template for Unity projects.
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get quite large
/[Mm]emoryCaptures/

# Asset store packages template (if you want to ignore imported packages)
# /[Aa]ssets/AssetStoreTools*

# Visual Studio cache directory
.vs/

# PlasticSCM cache directory
.plastic/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.class
*.pdb
*.opendb
*.db
*.meta.bin

# Unity3D generated meta files
# (Not recommended to ignore unless you know what you are doing, usually keep metas)
# *.meta

# Unity3D Generated File Types
sysinfo.txt
*.apk
*.unitypackage
*.aab

# Crashlytics generated file
crashlytics-build.properties

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini
